---
// src/components/admin/AnalyticsGrid.astro
const { analytics } = Astro.props
---

<div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-5 gap-4 w-full select-none">

  <div class="bg-white border border-zinc-200/60 p-4 rounded-xl shadow-sm flex flex-col justify-between min-h-[90px]">
    <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400 leading-none">Total Leads</p>
    <h3 class="text-2xl font-bold tracking-tight text-zinc-900 mt-2 leading-none">{analytics.total}</h3>
  </div>

  <div class="bg-white border border-zinc-200/60 p-4 rounded-xl shadow-sm flex flex-col justify-between min-h-[90px]">
    <div class="flex items-center justify-between w-full">
      <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400 leading-none">New</p>
      <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
    </div>
    <h3 class="text-2xl font-bold tracking-tight text-zinc-900 mt-2 leading-none">{analytics.newLeads}</h3>
  </div>

  <div class="bg-white border border-zinc-200/60 p-4 rounded-xl shadow-sm flex flex-col justify-between min-h-[90px]">
    <div class="flex items-center justify-between w-full">
      <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400 leading-none">Contacted</p>
      <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
    </div>
    <h3 class="text-2xl font-bold tracking-tight text-zinc-900 mt-2 leading-none">{analytics.contacted}</h3>
  </div>

  <div class="bg-white border border-zinc-200/60 p-4 rounded-xl shadow-sm flex flex-col justify-between min-h-[90px]">
    <div class="flex items-center justify-between w-full">
      <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400 leading-none">Won</p>
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
    </div>
    <h3 class="text-2xl font-bold tracking-tight text-zinc-900 mt-2 leading-none">{analytics.won}</h3>
  </div>

  <div class="bg-white border border-zinc-200/60 p-4 rounded-xl shadow-sm flex flex-col justify-between min-h-[90px]">
    <div class="flex items-center justify-between w-full">
      <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400 leading-none">Lost</p>
      <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span>
    </div>
    <h3 class="text-2xl font-bold tracking-tight text-zinc-900 mt-2 leading-none">{analytics.lost}</h3>
  </div>

</div>
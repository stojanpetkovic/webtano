---
const { lead } = Astro.props

if (!lead) {
  return null
}

// Mapa za stajling statusnog bedža
const statusStyles: Record<string, string> = {
  new: 'bg-blue-50 text-blue-700 border-blue-200',
  contacted: 'bg-amber-50 text-amber-700 border-amber-200',
  won: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  lost: 'bg-zinc-100 text-zinc-600 border-zinc-200'
}
---

<section class="bg-white border border-zinc-200/60 rounded-xl shadow-sm overflow-hidden select-none w-full">

  <div class="px-5 py-4 border-b border-zinc-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">

    <div class="flex items-center gap-3.5">
      <div class="w-12 h-12 rounded-lg bg-zinc-900 text-white flex items-center justify-center text-lg font-bold shrink-0 uppercase shadow-sm">
        {String(lead.name || 'L').charAt(0).toUpperCase()}
      </div>

      <div>
        <p class="text-[10px] uppercase tracking-[0.2em] text-zinc-400 font-bold leading-none">Lead Profile</p>
        <h1 class="text-lg font-bold tracking-tight text-zinc-900 mt-1.5 leading-none">
          {String(lead.name || '-')}
        </h1>
        <a
          href={`tel:${lead.phone}`}
          class="text-zinc-500 hover:text-zinc-950 transition text-xs font-semibold block mt-1 leading-none"
        >
          {String(lead.phone || '-')}
        </a>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2">

      <div class={`px-2.5 h-8 flex items-center rounded-lg text-xs font-bold border uppercase tracking-wider ${statusStyles[lead.status] || 'bg-zinc-50 text-zinc-700 border-zinc-200'}`}>
        {String(lead.status || 'new')}
      </div>

      <a
        href={`tel:${lead.phone}`}
        class="bg-zinc-900 hover:bg-zinc-800 text-white px-3 rounded-lg text-xs font-bold transition shadow-sm h-8 flex items-center gap-1 cursor-pointer"
      >
        <span>📞</span> Call
      </a>

      <a
        href={`https://wa.me/${String(lead.phone || '').replace(/\D/g, '')}`}
        target="_blank"
        class="bg-emerald-600 hover:bg-emerald-700 text-white px-3 rounded-lg text-xs font-bold transition shadow-sm h-8 flex items-center gap-1 cursor-pointer"
      >
        WhatsApp
      </a>

      <a
        href="/admin/leads"
        class="bg-zinc-100 hover:bg-zinc-200 text-zinc-800 px-3 rounded-lg text-xs font-bold transition h-8 flex items-center justify-center cursor-pointer border border-zinc-200/40"
      >
        Close
      </a>

    </div>

  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-5 p-5 items-start">

    <div class="xl:col-span-2 space-y-5">

      <div>
        <div class="mb-2">
          <p class="text-[10px] uppercase tracking-[0.15em] text-zinc-400 font-bold leading-none">Inquiry Detail</p>
          <h2 class="text-xs font-bold text-zinc-800 mt-1 leading-none">Customer Message</h2>
        </div>
        <div class="bg-zinc-50 border border-zinc-200/80 rounded-lg p-4 text-xs font-medium text-zinc-900 whitespace-pre-wrap leading-relaxed">
          {String(lead.message || 'No message left.')}
        </div>
      </div>

      <div>
        <div class="mb-2">
          <p class="text-[10px] uppercase tracking-[0.15em] text-zinc-400 font-bold leading-none">Internal System</p>
          <h2 class="text-xs font-bold text-zinc-800 mt-1 leading-none">CRM Notes</h2>
        </div>

        <textarea
          id={`notes-${lead.id}`}
          class="w-full min-h-[140px] bg-zinc-50 border border-zinc-200/80 rounded-lg p-4 text-xs font-semibold text-zinc-900 placeholder:text-zinc-400 outline-none focus:border-zinc-400 transition resize-none"
          placeholder="Write internal notes about this lead..."
        >{lead.notes || ''}</textarea>

        <div class="flex items-center justify-between mt-2">
          <p
            id={`notesSaved-${lead.id}`}
            class="text-xs font-bold text-emerald-600"
          ></p>

          <button
            class="saveNotesBtn bg-zinc-900 hover:bg-zinc-800 text-white px-4 h-8 rounded-lg text-xs font-bold transition shadow-sm cursor-pointer"
            data-id={lead.id}
          >
            Save Notes
          </button>
        </div>

      </div>

    </div>

    <div class="space-y-4">

      <div class="bg-zinc-50 border border-zinc-200/60 rounded-xl p-4">
        <h4 class="text-xs font-bold text-zinc-800 border-b border-zinc-200/60 pb-2 mb-3">Lead Metadata</h4>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <p class="text-[9px] uppercase tracking-wider text-zinc-400 font-bold">Source</p>
            <p class="text-zinc-900 text-xs font-bold mt-0.5">
              {String(lead.utm_source || lead.source || '-')}
            </p>
          </div>

          <div>
            <p class="text-[9px] uppercase tracking-wider text-zinc-400 font-bold">Campaign</p>
            <p class="text-zinc-900 text-xs font-bold mt-0.5 truncate">
              {String(lead.utm_campaign || '-')}
            </p>
          </div>

          <div class="col-span-2 pt-1.5 border-t border-zinc-200/40">
            <p class="text-[9px] uppercase tracking-wider text-zinc-400 font-bold">Timestamp</p>
            <p class="text-zinc-900 text-xs font-bold mt-0.5">
              {new Date(lead.created_at).toLocaleString('sr-RS')}
            </p>
          </div>
        </div>
      </div>

      <div class="bg-zinc-50 border border-zinc-200/60 rounded-xl p-4">
        <h4 class="text-xs font-bold text-zinc-800 border-b border-zinc-200/60 pb-2 mb-3">Audit Logs</h4>

        <div class="space-y-3">
          <div class="flex gap-2.5 items-start">
            <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-1 ring-4 ring-emerald-500/10 shrink-0"></div>
            <div>
              <p class="text-xs font-bold text-zinc-800 leading-none">Lead created</p>
              <p class="text-[10px] text-zinc-400 font-medium mt-1">
                {new Date(lead.created_at).toLocaleString('sr-RS', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}
              </p>
            </div>
          </div>

          <div class="flex gap-2.5 items-start pt-2 border-t border-zinc-200/40">
            <div class="w-1.5 h-1.5 rounded-full bg-blue-500 mt-1 ring-4 ring-blue-500/10 shrink-0"></div>
            <div>
              <p class="text-xs font-bold text-zinc-800 leading-none">State initialized</p>
              <p class="text-[10px] text-zinc-500 font-semibold mt-1">
                Current stage: <span class="text-zinc-900">{String(lead.status || 'new').toUpperCase()}</span>
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>
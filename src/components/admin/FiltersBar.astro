---
// src/components/admin/FiltersBar.astro
const { leadStatuses } = Astro.props
---

<div class="mb-4 select-none w-full">

  <div class="flex flex-row items-center justify-between gap-4 pb-3 border-b border-zinc-100">

    <div>
      <p class="text-[10px] uppercase tracking-[0.2em] text-zinc-400 font-bold leading-none">Pipeline View</p>
      <h2 class="text-lg font-bold tracking-tight text-zinc-900 mt-1.5 leading-none">
        Leads
      </h2>
    </div>

<div class="flex items-center gap-2">

      <div class="flex items-center bg-zinc-100 border border-zinc-200/80 p-0.5 rounded-lg h-8">
        <button
          id="tableViewBtn"
          class="viewToggleBtn bg-zinc-900 text-white px-3 h-full rounded-md text-xs font-bold shadow-sm transition cursor-pointer"
        >
          Table
        </button>

        <button
          id="kanbanViewBtn"
          class="viewToggleBtn px-3 h-full rounded-md text-xs font-bold text-zinc-600 hover:text-zinc-900 transition cursor-pointer"
        >
          Kanban
        </button>
      </div>

      <button
        id="exportExcelBtn"
        class="bg-zinc-900 hover:bg-zinc-800 text-white px-3 rounded-lg text-xs font-bold transition shadow-sm whitespace-nowrap h-8 flex items-center gap-1.5 cursor-pointer"
      >
        <span>📥</span>
        Export
      </button>

    </div>

  </div>

  <div
    id="advancedFilters"
    class="mt-3 bg-white border border-zinc-200/60 rounded-xl p-3 shadow-sm w-full"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-2.5">

      <div class="relative w-full">
        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 text-xs pointer-events-none">
          🔍
        </div>
        <input
          id="searchInput"
          type="text"
          placeholder="Search leads, phone..."
          class="w-full bg-zinc-50 border border-zinc-200/80 rounded-lg pl-8 pr-3 py-1.5 text-xs text-zinc-900 font-semibold placeholder:text-zinc-400 outline-none focus:border-zinc-400 transition h-8"
        />
      </div>

      <div class="relative w-full">
        <select
          id="statusFilter"
          class="appearance-none w-full bg-zinc-50 border border-zinc-200/80 rounded-lg px-3 py-1.5 pr-8 text-xs font-bold text-zinc-900 outline-none focus:border-zinc-400 transition cursor-pointer h-8"
        >
          <option value="" class="text-zinc-500 font-medium">All Statuses</option>
          {
            leadStatuses && leadStatuses.map((status: string) => (
              <option value={status} class="text-zinc-900 font-semibold">
                {status}
              </option>
            ))
          }
        </select>
        <div class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 pointer-events-none text-[9px]">
          ▼
        </div>
      </div>

      <div class="flex items-center justify-between gap-2 bg-zinc-50 border border-zinc-200/80 rounded-lg px-3 h-8">
        <span class="text-[9px] font-bold uppercase tracking-wider text-zinc-500 whitespace-nowrap">
          From
        </span>
        <input
          id="fromDate"
          type="date"
          class="bg-transparent text-xs font-bold text-zinc-900 outline-none cursor-pointer text-right w-full"
        />
      </div>

      <div class="flex items-center justify-between gap-2 bg-zinc-50 border border-zinc-200/80 rounded-lg px-3 h-8">
        <span class="text-[9px] font-bold uppercase tracking-wider text-zinc-500 whitespace-nowrap">
          To
        </span>
        <input
          id="toDate"
          type="date"
          class="bg-transparent text-xs font-bold text-zinc-900 outline-none cursor-pointer text-right w-full"
        />
      </div>

    </div>
  </div>

</div>
---
const {
  leads
} = Astro.props

const statuses = [

  {
    key: 'new',
    label: 'New',
    color: 'bg-blue-100 text-blue-700 border-blue-200',
    dot: 'bg-blue-500'
  },

  {
    key: 'contacted',
    label: 'Contacted',
    color: 'bg-amber-100 text-amber-700 border-amber-200',
    dot: 'bg-amber-500'
  },

  {
    key: 'won',
    label: 'Won',
    color: 'bg-emerald-100 text-emerald-700 border-emerald-200',
    dot: 'bg-emerald-500'
  },

  {
    key: 'lost',
    label: 'Lost',
    color: 'bg-rose-100 text-rose-700 border-rose-200',
    dot: 'bg-rose-500'
  }

]
---

<div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-4 gap-6 mt-8">

  {
    statuses.map((status) => {

      const filteredLeads =
        leads.filter(
          (lead: any) =>
            lead.status === status.key
        )

      return (

        <div
          class="kanban-column bg-white border border-zinc-200 rounded-[32px] shadow-sm flex flex-col overflow-hidden h-[85vh]"
          data-status={status.key}
        >

          <!-- HEADER -->

          <div class="flex items-center justify-between p-5 border-b border-zinc-100 shrink-0">

            <div class="flex items-center gap-3">

              <!-- DOT -->

              <div class={`w-3 h-3 rounded-full ${status.dot}`}></div>

              <!-- LABEL -->

              <div>

                <p class="text-xs uppercase tracking-[0.2em] text-zinc-400 font-semibold">

                  {status.label}

                </p>

                <p
                  class="text-3xl font-bold text-zinc-900 mt-1 kanban-count"
                >

                  {filteredLeads.length}

                </p>

              </div>

            </div>

            <!-- BADGE -->

            <div class={`px-3 py-1 rounded-full text-xs font-semibold border ${status.color}`}>

              Pipeline

            </div>

          </div>

          <!-- SCROLLABLE CARDS -->

          <div class="space-y-4 overflow-y-auto flex-1 min-h-0 p-5">

            {
              filteredLeads.map((lead: any) => (

                <div
                  class="lead-card bg-white border border-zinc-200 rounded-[26px] p-5 hover:shadow-md hover:border-zinc-300 transition cursor-grab active:cursor-grabbing"
                  draggable="true"
                  data-id={lead.id}
                  data-status={lead.status}
                >

                  <!-- TOP -->

                  <div class="flex items-start justify-between gap-3">

                    <!-- USER -->

                    <div class="flex items-center gap-3 min-w-0">

                      <!-- AVATAR -->

                      <div class="w-12 h-12 rounded-2xl bg-zinc-100 flex items-center justify-center text-sm font-bold text-zinc-700 shrink-0">

                        {
                          String(
                            lead.name || 'L'
                          )
                          .charAt(0)
                          .toUpperCase()
                        }

                      </div>

                      <!-- INFO -->

                      <div class="min-w-0">

                        <p class="font-semibold text-zinc-900 truncate">

                          {String(lead.name || '-')}

                        </p>

                        <a
                          href={`tel:${lead.phone}`}
                          class="text-green-600 hover:text-green-700 transition text-sm block mt-1"
                        >

                          {String(lead.phone || '-')}

                        </a>

                      </div>

                    </div>

                    <!-- STATUS -->

                    <div class={`shrink-0 px-2 py-1 rounded-full text-[10px] font-bold border ${status.color}`}>

                      {status.label}

                    </div>

                  </div>

                  <!-- MESSAGE -->

                  <div class="mt-5">

                    <p class="text-sm text-zinc-600 leading-relaxed line-clamp-4">

                      {
                        String(
                          lead.message ||
                          'No message'
                        )
                      }

                    </p>

                  </div>

                  <!-- FOOTER -->

                  <div class="flex items-center justify-between mt-6 pt-4 border-t border-zinc-100">

                    <p class="text-xs text-zinc-500">

                      {
                        new Date(
                          lead.created_at
                        ).toLocaleString()
                      }

                    </p>

                    <button
                      onclick={`openLeadDetails('${lead.id}')`}
                      class="bg-zinc-900 hover:bg-black text-white px-4 py-2 rounded-xl text-xs font-semibold transition shadow-sm"
                    >

                      Open

                    </button>

                  </div>

                </div>

              ))
            }

          </div>

        </div>

      )

    })
  }

</div>
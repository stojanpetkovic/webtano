---
// src/components/admin/KanbanBoard.astro
const { leads } = Astro.props

// Ujednačene, visoko profesionalne monohromatske/suptilne nijanse u skladu sa v2.0 sistemom
const statuses = [
  {
    key: 'new',
    label: 'New Leads',
    dot: 'bg-blue-500 ring-blue-500/10'
  },
  {
    key: 'contacted',
    label: 'Contacted',
    dot: 'bg-amber-500 ring-amber-500/10'
  },
  {
    key: 'won',
    label: 'Won Pipeline',
    dot: 'bg-emerald-500 ring-emerald-500/10'
  },
  {
    key: 'lost',
    label: 'Lost Archive',
    dot: 'bg-zinc-400 ring-zinc-400/10'
  }
]
---

<div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-4 gap-3.5 mt-1 items-start w-full select-none">
  {
    statuses.map((status) => {
      const filteredLeads = leads ? leads.filter((lead: any) => lead.status === status.key) : []

      return (
        /* KOLONA KANBANA: Utegnute ivice i stabilan proračun visine */
        <div
          class="kanban-column bg-white border border-zinc-200/60 rounded-xl shadow-sm flex flex-col h-[calc(100vh-165px)] min-h-[500px] overflow-hidden pb-1"
          data-status={status.key}
        >

          <div class="flex items-center justify-between p-3 border-b border-zinc-100 bg-zinc-50/20 shrink-0">
            <div class="flex items-center gap-2.5">
              <div class={`w-2 h-2 rounded-full ${status.dot} ring-4`}></div>
              <div class="flex items-center gap-1.5">
                <p class="text-xs font-bold text-zinc-900 tracking-tight">
                  {status.label}
                </p>
                <span class="text-[10px] font-black bg-zinc-100 text-zinc-600 px-1.5 py-0.5 rounded-md kanban-count">
                  {filteredLeads.length}
                </span>
              </div>
            </div>

            <div class="text-[9px] font-bold tracking-wider text-zinc-400 uppercase">
              Column
            </div>
          </div>

          <div class="space-y-2 p-2.5 bg-zinc-50/40 flex-1 overflow-y-auto min-h-0 no-scrollbar">
            {
              filteredLeads.length === 0 ? (
                <div class="text-center text-[10px] text-zinc-400 font-bold uppercase tracking-wider py-8 border border-dashed border-zinc-200/60 rounded-lg bg-white/50">
                  Empty
                </div>
              ) : (
                filteredLeads.map((lead: any) => (
                  /* KARTICA LIDA: Povećan kontrast i upeglan prostor */
                  <div
                    class="lead-card bg-white border border-zinc-200/60 rounded-lg p-3 hover:shadow-md hover:border-zinc-400/80 transition-all duration-150 cursor-grab active:cursor-grabbing group relative"
                    draggable="true"
                    data-id={lead.id}
                    data-status={lead.status}
                  >

                    <div class="flex items-start justify-between gap-2">
                      
                      <div class="flex items-center gap-2.5 min-w-0">
                        <div class="w-7 h-7 rounded-md bg-zinc-100 flex items-center justify-center text-[10px] font-bold text-zinc-600 shrink-0 uppercase">
                          {
                            String(lead.name || 'L')
                            .charAt(0)
                            .toUpperCase()
                          }
                        </div>

                        <div class="min-w-0">
                          <p class="font-bold text-zinc-900 text-xs truncate leading-tight">
                            {String(lead.name || '-')}
                          </p>
                          <a
                            href={`tel:${lead.phone}`}
                            class="text-zinc-500 hover:text-zinc-950 underline underline-offset-2 transition text-[10px] font-semibold block mt-1 leading-none"
                          >
                            {String(lead.phone || '-')}
                          </a>
                        </div>
                      </div>

                    </div>

                    <div class="mt-2.5">
                      <p class="text-[11px] text-zinc-600 leading-relaxed line-clamp-2 font-medium bg-zinc-50/50 rounded p-1.5 border border-zinc-100/50">
                        {String(lead.message || 'No message recorded.')}
                      </p>
                    </div>

                    <div class="flex items-center justify-between mt-3 pt-2 border-t border-zinc-100">
                      <p class="text-[10px] text-zinc-400 font-semibold uppercase tracking-wider">
                        {new Date(lead.created_at).toLocaleDateString('sr-RS', { day: 'numeric', month: 'short' })}
                      </p>

                      <a
                        href={`/admin/leads/${lead.id}`}
                        class="bg-zinc-900 hover:bg-zinc-800 text-white px-2.5 rounded-md text-[10px] font-bold transition shadow-sm inline-flex items-center justify-center h-6 cursor-pointer"
                      >
                        Open
                      </a>
                    </div>

                  </div>
                ))
              )
            }
          </div>

        </div>
      )
    })
  }
</div>
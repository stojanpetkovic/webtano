---
// src/components/admin/StatusSelect.astro
const {
  lead,
  leadStatuses = ['new', 'contacted', 'won', 'lost'] // Fallback da komponenta nikada ne pukne
} = Astro.props
---

<div class="relative inline-block text-left">
  <div class="flex items-center gap-2">

    <select
      id={`status-${lead.id}`}
      data-id={lead.id}
      data-current={lead.status}
      class="bg-zinc-50 border border-zinc-200/80 hover:border-zinc-300 rounded-lg px-2.5 text-xs font-bold text-zinc-900 outline-none transition shadow-sm min-w-[130px] h-8 cursor-pointer capitalize pr-8 appearance-none"
      style="background-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%2371717a\' stroke-width=\'3\' stroke-linecap=\'round\' stroke-linejoin=\'round\'><polyline points=\'6 9 12 15 18 9\'></polyline></svg>'); background-repeat: no-repeat; background-position: right 10px center; background-size: 10px;"
    >
      {
        leadStatuses.map((status: string) => (
          <option
            value={status}
            selected={lead.status === status}
            class="capitalize font-semibold text-zinc-950"
          >
            {status}
          </option>
        ))
      }
    </select>

    <button
      class="saveStatusBtn bg-emerald-600 hover:bg-emerald-700 text-white px-3 rounded-lg text-xs font-bold transition shadow-sm whitespace-nowrap h-8 flex items-center justify-center cursor-pointer"
      data-id={lead.id}
    >
      Save
    </button>

  </div>

  <p
    id={`saved-${lead.id}`}
    class="text-[10px] font-bold text-emerald-600 mt-1 absolute left-0 transition-all duration-150"
  ></p>
</div>
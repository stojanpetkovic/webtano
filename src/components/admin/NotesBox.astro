---
const {
  lead
} = Astro.props
---

<div class="mt-6">

  <!-- HEADER -->

  <div class="flex items-center justify-between mb-2">

    <div>

      <p class="text-[11px] uppercase tracking-[0.15em] text-zinc-400 font-semibold">
        Internal Notes
      </p>

    </div>

    <p
      id={`notesSaved-${lead.id}`}
      class="text-[11px] text-zinc-500"
    ></p>

  </div>

  <!-- TEXTAREA -->

  <textarea
    id={`notes-${lead.id}`}
    class="w-full min-h-[110px] bg-zinc-50 border border-zinc-200 rounded-2xl px-4 py-3 text-sm text-zinc-800 outline-none focus:border-zinc-400 focus:ring-4 focus:ring-zinc-100 transition resize-none leading-relaxed"
    placeholder="Add notes..."
  >{lead.notes || ''}</textarea>

  <!-- BUTTON -->

  <div class="flex justify-end mt-3">

    <button
      class="saveNotesBtn bg-zinc-900 hover:bg-black text-white px-4 py-2.5 rounded-xl text-xs font-semibold transition shadow-sm"
      data-id={lead.id}
    >

      Save Notes

    </button>

  </div>

</div>
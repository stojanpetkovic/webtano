---
// src/components/admin/NotesBox.astro
const {
  lead
} = Astro.props
---

<div class="mt-5">

  <div class="flex items-center justify-between mb-2 select-none">
    <div>
      <p class="text-[9px] uppercase tracking-wider text-zinc-400 font-bold">
        Internal CRM Notes
      </p>
    </div>

    <p
      id={`notesSaved-${lead.id}`}
      class="text-xs font-bold text-emerald-600 transition-all"
    ></p>
  </div>

  <textarea
    id={`notes-${lead.id}`}
    class="w-full min-h-[90px] bg-zinc-50 border border-zinc-200/80 rounded-lg p-3 text-xs font-semibold text-zinc-900 placeholder:text-zinc-400 outline-none focus:border-zinc-400 transition resize-none leading-relaxed"
    placeholder="Add quick internal notes about this lead..."
  >{lead.notes || ''}</textarea>

  <div class="flex justify-end mt-2">
    <button
      class="saveNotesBtn bg-zinc-900 hover:bg-zinc-800 text-white px-3 h-8 rounded-lg text-xs font-bold transition shadow-sm cursor-pointer"
      data-id={lead.id}
    >
      Save Notes
    </button>
  </div>

</div>
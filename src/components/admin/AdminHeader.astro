---
// src/components/admin/AdminHeader.astro
const { businessName } = Astro.props
---

<header class="w-full h-[60px] bg-white border-b border-zinc-200/60 px-6 flex items-center justify-between shrink-0 select-none z-30 relative">
  
  <div class="flex items-center gap-3">
    <p class="text-[10px] uppercase tracking-[0.25em] text-zinc-400 font-bold leading-none border-r border-zinc-200 pr-3 h-3 flex items-center">
      Workspace
    </p>
    <h1 class="text-xs font-bold tracking-tight text-zinc-900 leading-none">
      {businessName || 'Control Panel'}
    </h1>
  </div>

  <div class="flex items-center gap-3">
    
    <div class="flex items-center gap-2 bg-zinc-50 border border-zinc-200/60 p-1 pr-3 rounded-xl h-8">
      <div class="w-6 h-6 rounded-lg bg-zinc-900 text-white flex items-center justify-center font-bold text-[10px] shadow-sm uppercase">
        {businessName ? businessName.charAt(0).toUpperCase() : 'W'}
      </div>
      <div class="hidden sm:block text-left">
        <p class="text-[11px] font-bold text-zinc-800 leading-none">
          Admin
        </p>
      </div>
    </div>

    <div class="w-[1px] h-4 bg-zinc-200/80"></div>

    <button
      id="logoutBtn"
      class="bg-white hover:bg-rose-50 text-zinc-600 hover:text-rose-600 border border-zinc-200/80 hover:border-rose-200/60 px-3 rounded-xl text-[11px] font-bold transition-all duration-150 shadow-sm flex items-center gap-1.5 group h-8 cursor-pointer"
    >
      <span class="text-[10px] transition-transform group-hover:translate-x-0.5">➔</span>
      Logout
    </button>

  </div>

</header>

<script
  define:vars={{
    supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL,
    supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  }}
  type="module"
>
  import { createClient } from 'https://esm.sh/@supabase/supabase-js'

  // Inicijalizacija Supabase klijenta unutar headera
  const supabase = createClient(supabaseUrl, supabaseKey)
  const logoutButton = document.getElementById('logoutBtn')

  logoutButton?.addEventListener('click', async (e) => {
    e.preventDefault()

    try {
      // Gasimo sesiju na Supabase serveru
      await supabase.auth.signOut()

      // Čistimo skladišta brauzera za maksimalnu bezbednost
      localStorage.clear()
      sessionStorage.clear()

      // ISPRAVLJENO: Vraćamo korisnika direktno na /login
      window.location.href = '/login'
      
    } catch (err) {
      console.error('Greška tokom odjavljivanja:', err)
      // Ako API privremeno štuca, ipak prisilno izbaci korisnika na login stranu
      window.location.href = '/login'
    }
  })
</script>
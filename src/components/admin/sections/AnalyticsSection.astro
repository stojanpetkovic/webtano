---
// src/components/admin/AnalyticsSection.astro
import LeadTrendsChart from '../LeadTrendsChart.astro'

const { allLeads } = Astro.props

// Defanzivna provera za siguran rad aplikacije
const safeLeads = allLeads || []
const totalLeads = safeLeads.length

// =========================
// PIPELINE COUNTS
// =========================
const newLeads = safeLeads.filter((lead: any) => lead.status === 'new').length
const contactedLeads = safeLeads.filter((lead: any) => lead.status === 'contacted').length
const wonLeads = safeLeads.filter((lead: any) => lead.status === 'won').length

// =========================
// SOURCE ANALYTICS
// =========================
const sourceAnalytics = Object.entries(
  safeLeads.reduce((acc: any, lead: any) => {
    const source = String(lead.utm_source || lead.source || 'unknown')
      .trim()
      .toLowerCase()

    if (!acc[source]) {
      acc[source] = {
        total: 0,
        won: 0
      }
    }

    acc[source].total++

    if (lead.status === 'won') {
      acc[source].won++
    }

    return acc
  }, {})
)
---

<section
  id="analyticsSection"
  class="dashboard-section hidden"
>
  <div class="space-y-10">

    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5">
      <div>
        <p class="text-sm font-medium text-zinc-500">
          CRM Insights
        </p>
        <h2 class="text-4xl font-bold tracking-tight text-zinc-900 mt-1">
          Analytics
        </h2>
      </div>

      <div class="flex items-center gap-3">
        <div class="bg-white border border-zinc-200 rounded-2xl px-5 py-3 shadow-sm min-w-[150px]">
          <p class="text-xs uppercase tracking-[0.14em] text-zinc-400 font-bold">
            Total Leads
          </p>
          <p class="text-3xl font-extrabold text-zinc-900 mt-1">
            {totalLeads}
          </p>
        </div>
      </div>
    </div>

    <LeadTrendsChart leads={safeLeads} />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

      <div class="bg-white border border-zinc-200 rounded-[24px] p-6 shadow-sm flex flex-col justify-between">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.14em] text-zinc-400 font-bold">New</p>
            <h3 class="text-5xl font-bold tracking-tight text-zinc-900 mt-3">{newLeads}</h3>
          </div>
          <div class="w-12 h-12 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center text-xl shrink-0">
            🆕
          </div>
        </div>
        <div class="mt-6">
          <div class="h-2 bg-zinc-100 rounded-full overflow-hidden">
            <div
              class="h-full bg-blue-500 rounded-full transition-all duration-500"
              style={`width: ${totalLeads > 0 ? (newLeads / totalLeads) * 100 : 0}%`}
            ></div>
          </div>
          <p class="text-[11px] text-zinc-400 font-medium mt-2">
            {totalLeads > 0 ? Math.round((newLeads / totalLeads) * 100) : 0}% of pipeline
          </p>
        </div>
      </div>

      <div class="bg-white border border-zinc-200 rounded-[24px] p-6 shadow-sm flex flex-col justify-between">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.14em] text-zinc-400 font-bold">Contacted</p>
            <h3 class="text-5xl font-bold tracking-tight text-zinc-900 mt-3">{contactedLeads}</h3>
          </div>
          <div class="w-12 h-12 rounded-xl bg-amber-50 border border-amber-100 flex items-center justify-center text-xl shrink-0">
            📞
          </div>
        </div>
        <div class="mt-6">
          <div class="h-2 bg-zinc-100 rounded-full overflow-hidden">
            <div
              class="h-full bg-amber-500 rounded-full transition-all duration-500"
              style={`width: ${totalLeads > 0 ? (contactedLeads / totalLeads) * 100 : 0}%`}
            ></div>
          </div>
          <p class="text-[11px] text-zinc-400 font-medium mt-2">
            {totalLeads > 0 ? Math.round((contactedLeads / totalLeads) * 100) : 0}% of pipeline
          </p>
        </div>
      </div>

      <div class="bg-white border border-zinc-200 rounded-[24px] p-6 shadow-sm flex flex-col justify-between">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.14em] text-zinc-400 font-bold">Won</p>
            <h3 class="text-5xl font-bold tracking-tight text-emerald-600 mt-3">{wonLeads}</h3>
          </div>
          <div class="w-12 h-12 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-xl shrink-0">
            💰
          </div>
        </div>
        <div class="mt-6">
          <div class="h-2 bg-zinc-100 rounded-full overflow-hidden">
            <div
              class="h-full bg-emerald-500 rounded-full transition-all duration-500"
              style={`width: ${totalLeads > 0 ? (wonLeads / totalLeads) * 100 : 0}%`}
            ></div>
          </div>
          <p class="text-[11px] text-zinc-400 font-medium mt-2">
            {totalLeads > 0 ? Math.round((wonLeads / totalLeads) * 100) : 0}% of pipeline
          </p>
        </div>
      </div>

    </div>

    <div class="pt-4">
      <div class="mb-6">
        <p class="text-sm font-medium text-zinc-500">Lead Sources</p>
        <h3 class="text-3xl font-bold tracking-tight text-zinc-900 mt-1">Source Performance</h3>
      </div>

      {sourceAnalytics.length === 0 ? (
        <div class="bg-white border border-zinc-200 rounded-[24px] p-12 text-center text-zinc-400 text-sm">
          No source tracking data available yet.
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5">
          {sourceAnalytics.map(([source, data]: any) => {
            const conversion = data.total > 0 ? Math.round((data.won / data.total) * 100) : 0
            
            return (
              <div class="bg-white border border-zinc-200 rounded-[24px] p-6 shadow-sm flex flex-col justify-between min-h-[220px]">
                <div>
                  <p class="text-xs uppercase tracking-wider text-zinc-400 font-bold capitalize">
                    {source}
                  </p>
                  <h3 class="text-5xl font-extrabold tracking-tight text-zinc-900 mt-4">
                    {data.total}
                  </h3>
                  <p class="text-xs text-zinc-400 mt-1">Total Registered Leads</p>
                </div>

                <div class="flex items-end justify-between mt-6 pt-4 border-t border-zinc-100">
                  <div>
                    <p class="text-[10px] uppercase tracking-wider text-zinc-400 font-bold">Won</p>
                    <p class="text-xl font-bold text-emerald-600 mt-0.5">{data.won}</p>
                  </div>
                  <div class="text-right">
                    <p class="text-[10px] uppercase tracking-wider text-zinc-400 font-bold">Conversion</p>
                    <p class="text-xl font-bold text-zinc-900 mt-0.5">{conversion}%</p>
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      )}
    </div>

  </div>
</section>
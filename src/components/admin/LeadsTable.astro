---
// src/components/admin/LeadsTable.astro
import LeadModal from './LeadModal.astro'
import StatusSelect from './StatusSelect.astro'

const {
  leads,
  leadStatuses
} = Astro.props

const typedLeads = leads || []
---

<div class="overflow-hidden overflow-x-auto rounded-xl border border-zinc-200/60 bg-white shadow-sm select-none w-full">

  <table class="w-full min-w-[1000px] text-xs text-left border-collapse">

    <thead class="bg-zinc-50 border-b border-zinc-200/60">
      <tr>
        <th class="px-4 py-2.5 text-[10px] font-bold uppercase tracking-wider text-zinc-400">
          Lead Info
        </th>
        <th class="px-4 py-2.5 text-[10px] font-bold uppercase tracking-wider text-zinc-400">
          Source
        </th>
        <th class="px-4 py-2.5 text-[10px] font-bold uppercase tracking-wider text-zinc-400">
          Campaign
        </th>
        <th class="px-4 py-2.5 text-[10px] font-bold uppercase tracking-wider text-zinc-400">
          Status
        </th>
        <th class="px-4 py-2.5 text-[10px] font-bold uppercase tracking-wider text-zinc-400 text-right pr-6">
          Actions
        </th>
      </tr>
    </thead>

    <tbody class="divide-y divide-zinc-100">
      {
        typedLeads.map((lead: any, index: number) => (
          <tr class="hover:bg-zinc-50/60 transition-colors duration-100 group">

            <td class="px-4 py-2.5">
              <div class="flex items-center gap-3">
                
                <div class="w-7 h-7 rounded-md bg-zinc-100 flex items-center justify-center text-[10px] font-bold text-zinc-600 shrink-0 uppercase">
                  {
                    String(lead.name || 'L')
                    .charAt(0)
                    .toUpperCase()
                  }
                </div>

                <div class="min-w-0">
                  <p class="font-bold text-zinc-900 text-xs truncate leading-tight">
                    {String(lead.name || '-')}
                  </p>
                  <p class="text-[10px] text-zinc-400 font-medium mt-0.5 leading-none lead-date" data-date={lead.created_at}>
                    {new Date(lead.created_at).toLocaleString('sr-RS', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}
                  </p>
                </div>

              </div>
            </td>

            <td class="px-4 py-2.5">
              <span class="inline-flex items-center rounded-md bg-zinc-50 px-2 py-0.5 text-[10px] font-bold text-zinc-800 border border-zinc-200/60 uppercase tracking-wide">
                {String(lead.utm_source || lead.source || '-')}
              </span>
            </td>

            <td class="px-4 py-2.5">
              <div class="max-w-[200px] truncate text-zinc-600 font-semibold text-xs">
                {String(lead.utm_campaign || '-')}
              </div>
            </td>

            <td class="px-4 py-2.5">
              <StatusSelect
                lead={lead}
                leadStatuses={leadStatuses}
              />
            </td>

            <td class="px-4 py-2.5 text-right pr-6">
              <div class="flex items-center justify-end gap-2">

                <LeadModal
                  lead={lead}
                  index={index}
                />

                <a
                  href={`/admin/leads/${lead.id}`}
                  class="bg-zinc-900 hover:bg-zinc-800 text-white px-3 rounded-lg text-xs font-bold transition shadow-sm inline-flex items-center justify-center h-8 cursor-pointer"
                >
                  Details
                </a>

              </div>
            </td>

          </tr>
        ))
      }
    </tbody>

  </table>

</div>
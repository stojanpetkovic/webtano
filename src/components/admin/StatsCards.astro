---
// src/components/admin/AnalyticsGrid.astro
const { analytics } = Astro.props

// Defanzivna provera koja obezbeđuje da kod ne pukne ako podaci privremeno kasne
const safeAnalytics = analytics || {
  total: 0,
  newLeads: 0,
  contacted: 0,
  won: 0,
  lost: 0
}

// Konfigurišemo kartice po v2.0 standardu (čist kontrast i suptilni akcenti na brojevima)
const cards = [
  {
    label: 'Total Leads',
    value: safeAnalytics.total ?? 0,
    valueColor: 'text-zinc-900',
    icon: '📋'
  },
  {
    label: 'New Leads',
    value: safeAnalytics.newLeads ?? 0,
    valueColor: 'text-blue-600',
    icon: '✨'
  },
  {
    label: 'Contacted',
    value: safeAnalytics.contacted ?? 0,
    valueColor: 'text-amber-600',
    icon: '📞'
  },
  {
    label: 'Won Pipeline',
    value: safeAnalytics.won ?? 0,
    valueColor: 'text-emerald-600',
    icon: '🏆'
  },
  {
    label: 'Lost Archive',
    value: safeAnalytics.lost ?? 0,
    valueColor: 'text-zinc-400',
    icon: '✕'
  }
]
---

<div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-5 gap-3 select-none w-full">
  {
    cards.map((card) => (
      <div class="bg-white border border-zinc-200/60 rounded-xl p-3.5 shadow-sm hover:border-zinc-300 transition-all duration-150 flex flex-col justify-between min-h-[90px] group relative overflow-hidden">
        
        <div class="flex items-center justify-between">
          
          <div class="w-7 h-7 rounded-md bg-zinc-50 border border-zinc-200/60 flex items-center justify-center text-xs text-zinc-600 shrink-0">
            {card.icon}
          </div>

          <p class={`text-xl font-black tracking-tight ${card.valueColor}`}>
            {card.value}
          </p>
        </div>

        <p class="text-[9px] uppercase tracking-wider text-zinc-400 font-bold mt-4 leading-none">
          {card.label}
        </p>

      </div>
    ))
  }
</div>
---
import Layout
from '../layouts/Layout.astro'

import { client }
from '../config/client'

import Sidebar
from '../components/admin/Sidebar.astro'

import DashboardSection
from '../components/admin/sections/DashboardSection.astro'

import LeadsSection
from '../components/admin/sections/LeadsSection.astro'

import AnalyticsSection
from '../components/admin/sections/AnalyticsSection.astro'

import LeadDetails
from '../components/admin/LeadDetails.astro'

import {
  getLeads,
  getLeadAnalytics
}
from '../lib/client/leads.js'

import appScript
from '../scripts/admin/app.js?url'

// =========================
// CLIENT
// =========================

const clientId =
  client.id

// =========================
// LOAD LEADS
// =========================

const allLeads =
  await getLeads(
    clientId
  )

const leads =
  allLeads || []

// =========================
// ANALYTICS
// =========================

const analytics =
  getLeadAnalytics(
    leads
  )

// =========================
// PAGINATION
// =========================

const totalPages =
  Math.ceil(
    leads.length / 10
  )

// =========================
// LEAD DETAILS
// =========================

const selectedLeadId =
  Astro.url.searchParams.get(
    'lead'
  )

const selectedLead =
  leads.find(
    (lead: any) =>

      String(lead.id) ===
      String(selectedLeadId)

  ) || leads[0]

---

<Layout>

  <main class="min-h-screen bg-[#f5f7fb] text-zinc-900 flex">

    <!-- SIDEBAR -->

    <Sidebar
      businessName={client.businessName}
    />

    <!-- CONTENT -->

    <div class="flex-1 min-w-0">

      <!-- TOPBAR -->

      <div class="sticky top-0 z-30 bg-white/80 backdrop-blur-xl border-b border-zinc-200">

        <div class="px-8 py-5 flex items-center justify-between">

          <!-- LEFT -->

          <div>

            <p class="text-sm text-zinc-500">
              Welcome back 👋
            </p>

            <h1 class="text-3xl font-bold tracking-tight text-zinc-900">
              CRM Dashboard
            </h1>

          </div>

          <!-- RIGHT -->

          <div class="flex items-center gap-4">

            <!-- USER -->

            <div class="hidden md:flex items-center gap-3">

              <div class="text-right">

                <p class="text-sm font-semibold text-zinc-900">
                  Admin
                </p>

                <p class="text-xs text-zinc-500">
                  CRM Manager
                </p>

              </div>

              <div class="w-11 h-11 rounded-2xl bg-zinc-100 flex items-center justify-center text-sm font-bold text-zinc-700">

                A

              </div>

            </div>

            <!-- LOGOUT -->

            <button
              id="logoutBtn"
              class="bg-red-50 hover:bg-red-100 border border-red-200 text-red-500 px-4 py-2.5 rounded-2xl text-sm font-semibold transition"
            >

              Logout

            </button>

          </div>

        </div>

      </div>

      <!-- MAIN -->

      <div class="p-8 space-y-10">

        <!-- DASHBOARD -->

        <DashboardSection
          analytics={analytics}
          leads={leads}
        />

        <!-- LEADS -->

        <LeadsSection
          leads={leads}
          totalPages={totalPages}
          leadStatuses={client.leadStatuses}
        />

        <!-- ANALYTICS -->

        <AnalyticsSection
          allLeads={allLeads}
        />

        <!-- SETTINGS -->

        <section
          id="settingsSection"
          class="dashboard-section hidden"
        >

          <div class="bg-white border border-zinc-200 rounded-[32px] p-10 shadow-sm">

            <p class="text-sm text-zinc-500 font-medium">
              Settings
            </p>

            <h2 class="text-4xl font-bold tracking-tight text-zinc-900 mt-2">
              CRM Settings
            </h2>

            <p class="text-zinc-500 mt-4 leading-relaxed max-w-2xl">
              Settings panel coming soon.
            </p>

          </div>

        </section>

        <!-- LEAD DETAILS -->

        <section
          id="leadDetailsSection"
          class="dashboard-section hidden"
        >

          <LeadDetails
            lead={selectedLead}
          />

        </section>

      </div>

    </div>

  </main>

</Layout>

<script
  type="module"
  src={appScript}
></script>
---
// src/pages/admin/analytics.astro
import AdminLayout from '../../layouts/AdminLayout.astro';
import AnalyticsGrid from '../../components/admin/AnalyticsGrid.astro';

// Fiktivni podaci za inicijalni grid koji već imaš
const mockAnalytics = {
  total: 1248,
  totalCalls: 432,
  newLeads: 184,
  contacted: 522,
  won: 412,
  lost: 130
};
---

<AdminLayout title="Business Analytics | WebTano CRM">
  <div class="space-y-6">
    
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 pb-5 border-b border-zinc-200/60">
      <div>
        <h1 class="text-xl font-bold tracking-tight text-zinc-900">Performance & Analytics</h1>
        <p class="text-xs text-zinc-500 mt-1">Real-time traffic acquisition, conversion funnel and campaign tracking.</p>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-[11px] font-bold text-zinc-600 uppercase tracking-wider">Live Traffic Sync</span>
      </div>
    </div>

    <AnalyticsGrid analytics={mockAnalytics} />

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <div class="bg-white border border-zinc-200/60 p-5 rounded-xl shadow-sm lg:col-span-2 flex flex-col justify-between">
        <div class="mb-4">
          <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400">Traffic Acquisition</p>
          <h3 class="text-sm font-bold text-zinc-900 mt-0.5">Clicks & Conversions Over Time</h3>
        </div>
        
        <div class="h-[280px] w-full relative">
          <canvas id="trafficChart"></canvas>
        </div>
      </div>

      <div class="bg-white border border-zinc-200/60 p-5 rounded-xl shadow-sm flex flex-col justify-between">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400">Conversion Rates</p>
          <h3 class="text-sm font-bold text-zinc-900 mt-0.5">Leads Funnel Efficiency</h3>
        </div>

        <div class="space-y-4 my-auto py-4">
          <div>
            <div class="flex justify-between text-xs font-bold text-zinc-700 mb-1.5">
              <span>Total Clicks (Ads + Social)</span>
              <span>14,820</span>
            </div>
            <div class="w-full bg-zinc-100 h-2 rounded-full overflow-hidden">
              <div class="bg-zinc-400 h-full w-full"></div>
            </div>
          </div>

          <div>
            <div class="flex justify-between text-xs font-bold text-zinc-700 mb-1.5">
              <span>Leads Generated (Conversion Rate)</span>
              <span class="text-blue-600">1,248 <span class="text-[10px] text-zinc-400 font-medium">(8.4%)</span></span>
            </div>
            <div class="w-full bg-zinc-100 h-2 rounded-full overflow-hidden">
              <div class="bg-blue-500 h-full w-[8.4%]"></div>
            </div>
          </div>

          <div>
            <div class="flex justify-between text-xs font-bold text-zinc-700 mb-1.5">
              <span>Deals Won (Close Rate)</span>
              <span class="text-emerald-600">412 <span class="text-[10px] text-zinc-400 font-medium">(33.0%)</span></span>
            </div>
            <div class="w-full bg-zinc-100 h-2 rounded-full overflow-hidden">
              <div class="bg-emerald-500 h-full w-[33%]"></div>
            </div>
          </div>
        </div>

        <div class="bg-zinc-50 border border-zinc-100 rounded-lg p-3 text-center">
          <p class="text-[10px] text-zinc-400 font-bold uppercase">ROI Metric</p>
          <p class="text-lg font-black text-zinc-900 mt-0.5">3.4x <span class="text-xs font-bold text-emerald-600">+12% moM</span></p>
        </div>
      </div>

    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <div class="bg-white border border-zinc-200/60 rounded-xl shadow-sm p-5 overflow-hidden">
        <div class="mb-4">
          <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400">Acquisition Channels</p>
          <h3 class="text-sm font-bold text-zinc-900 mt-0.5">Campaign Performance</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-xs">
            <thead>
              <tr class="border-b border-zinc-100 text-zinc-400 font-bold uppercase tracking-wider text-[10px]">
                <th class="pb-2">Channel / Campaign</th>
                <th class="pb-2 text-right">Clicks</th>
                <th class="pb-2 text-right">Leads</th>
                <th class="pb-2 text-right">Cost</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100 font-medium text-zinc-800">
              <tr>
                <td class="py-3 flex items-center gap-2">
                  <span class="text-blue-500 text-sm">🌐</span> 
                  <div>
                    <p class="font-bold text-zinc-900">Google Ads</p>
                    <p class="text-[9px] text-zinc-400 font-semibold uppercase">Search_Intent_2026</p>
                  </div>
                </td>
                <td class="py-3 text-right font-bold">6,420</td>
                <td class="py-3 text-right text-blue-600 font-bold">580</td>
                <td class="py-3 text-right text-zinc-500">$420.50</td>
              </tr>
              <tr>
                <td class="py-3 flex items-center gap-2">
                  <span class="text-indigo-500 text-sm">👥</span>
                  <div>
                    <p class="font-bold text-zinc-900">Meta / Instagram Ads</p>
                    <p class="text-[9px] text-zinc-400 font-semibold uppercase">Lookalike_Audience_v2</p>
                  </div>
                </td>
                <td class="py-3 text-right font-bold">4,110</td>
                <td class="py-3 text-right text-blue-600 font-bold">342</td>
                <td class="py-3 text-right text-zinc-500">$310.20</td>
              </tr>
              <tr>
                <td class="py-3 flex items-center gap-2">
                  <span class="text-red-500 text-sm">🎥</span>
                  <div>
                    <p class="font-bold text-zinc-900">YouTube Video</p>
                    <p class="text-[9px] text-zinc-400 font-semibold uppercase">Product_Review_Influencer</p>
                  </div>
                </td>
                <td class="py-3 text-right font-bold">2,850</td>
                <td class="py-3 text-right text-blue-600 font-bold">194</td>
                <td class="py-3 text-right text-zinc-500">$150.00</td>
              </tr>
              <tr>
                <td class="py-3 flex items-center gap-2">
                  <span class="text-zinc-600 text-sm">🔗</span>
                  <div>
                    <p class="font-bold text-zinc-900">Organic / Direct</p>
                    <p class="text-[9px] text-zinc-400 font-semibold uppercase">SEO Optimization</p>
                  </div>
                </td>
                <td class="py-3 text-right font-bold">1,440</td>
                <td class="py-3 text-right text-blue-600 font-bold">132</td>
                <td class="py-3 text-right text-zinc-500">$0.00</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="bg-white border border-zinc-200/60 rounded-xl shadow-sm p-5 overflow-hidden">
        <div class="mb-4">
          <p class="text-[10px] font-bold uppercase tracking-wider text-zinc-400">Content Performance</p>
          <h3 class="text-sm font-bold text-zinc-900 mt-0.5">Top Converting Pages</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-xs">
            <thead>
              <tr class="border-b border-zinc-100 text-zinc-400 font-bold uppercase tracking-wider text-[10px]">
                <th class="pb-2">Page URL</th>
                <th class="pb-2 text-right">Views</th>
                <th class="pb-2 text-right">Avg. Time</th>
                <th class="pb-2 text-right">Bounce</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100 font-medium text-zinc-800">
              <tr>
                <td class="py-3 text-zinc-900 font-bold truncate max-w-[180px]">/products/web-development</td>
                <td class="py-3 text-right font-bold">5,120</td>
                <td class="py-3 text-right text-zinc-600">2m 14s</td>
                <td class="py-3 text-right text-rose-600 font-bold">41.2%</td>
              </tr>
              <tr>
                <td class="py-3 text-zinc-900 font-bold truncate max-w-[180px]">/landing/pricing-plans</td>
                <td class="py-3 text-right font-bold">3,890</td>
                <td class="py-3 text-right text-zinc-600">1m 45s</td>
                <td class="py-3 text-right text-emerald-600 font-bold">29.8%</td>
              </tr>
              <tr>
                <td class="py-3 text-zinc-900 font-bold truncate max-w-[180px]">/homepage</td>
                <td class="py-3 text-right font-bold">2,440</td>
                <td class="py-3 text-right text-zinc-600">0m 52s</td>
                <td class="py-3 text-right text-rose-600 font-bold text-zinc-400">55.1%</td>
              </tr>
              <tr>
                <td class="py-3 text-zinc-900 font-bold truncate max-w-[180px]">/blog/how-to-scale-business</td>
                <td class="py-3 text-right font-bold">1,150</td>
                <td class="py-3 text-right text-zinc-600">3m 02s</td>
                <td class="py-3 text-right text-emerald-600 font-bold">34.5%</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</AdminLayout>

<script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const ctx = document.getElementById('trafficChart');
    if (!ctx) return;

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [
          {
            label: 'Google Ads Clicks',
            data: [1200, 1900, 3200, 4100, 4800, 6420],
            borderColor: '#3b82f6', // blue-500
            borderWidth: 2,
            pointRadius: 3,
            tension: 0.3,
            fill: false
          },
          {
            label: 'Social Network Clicks',
            data: [800, 1500, 2100, 2900, 3400, 4110],
            borderColor: '#6366f1', // indigo-500
            borderWidth: 2,
            pointRadius: 3,
            tension: 0.3,
            fill: false
          },
          {
            label: 'Conversions (Leads)',
            data: [110, 240, 450, 710, 920, 1248],
            borderColor: '#10b981', // emerald-500
            borderWidth: 2,
            pointRadius: 4,
            backgroundColor: '#10b981',
            tension: 0.1,
            fill: false
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'top',
            labels: {
              boxWidth: 12,
              font: { size: 11, weight: '600', family: 'sans-serif' },
              color: '#18181b'
            }
          }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { font: { size: 10, weight: '600' }, color: '#a1a1aa' }
          },
          y: {
            grid: { color: '#f4f4f5' },
            ticks: { font: { size: 10, weight: '600' }, color: '#a1a1aa' }
          }
        }
      }
    });
  });
</script>